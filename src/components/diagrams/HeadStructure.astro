---
const CIRCLE_R = 10;
const NUM_HEADS = 8;
const COL_W = 220;
const COL_GAP = 20;
const PAD_X = 20;
const PAD_TOP = 30;
const Q_Y = PAD_TOP + CIRCLE_R;
const KV_Y = Q_Y + 80;
const KV_W = 24;
const KV_H = 16;
const SUBLABEL_Y = KV_Y + KV_H + 24;
const TOTAL_W = PAD_X * 2 + 3 * COL_W + 2 * COL_GAP;
const TOTAL_H = SUBLABEL_Y + 16 + 10;

const colX = [
  PAD_X,
  PAD_X + COL_W + COL_GAP,
  PAD_X + 2 * (COL_W + COL_GAP),
];

// Query circle centers for each column
function qxArr(cx: number): number[] {
  return Array.from({ length: NUM_HEADS }, (_, i) => cx + (i + 0.5) * (COL_W / NUM_HEADS));
}

// KV rect center-x positions per column
const kvCenters: Record<number, number[]> = {
  0: qxArr(colX[0]),                                         // MHA: 8 rects
  1: [colX[1] + COL_W / 2],                                 // MQA: 1 rect
  2: [colX[2] + COL_W / 4, colX[2] + 3 * COL_W / 4],       // GQA: 2 rects
};

// For each query head i in column col, return the center-x of its target KV rect
function kvTargetX(col: number, i: number): number {
  if (col === 0) return kvCenters[0][i];
  if (col === 1) return kvCenters[1][0];
  return kvCenters[2][i < 4 ? 0 : 1];
}

const columns = [
  { label: 'Multi-Head Attention', sublabel: '1× cache (baseline)' },
  { label: 'Multi-Query Attention', sublabel: '8× smaller cache' },
  { label: 'Group Query Attention', sublabel: '4× smaller cache' },
];
---

<svg
  width="100%"
  viewBox={`0 0 ${TOTAL_W} ${TOTAL_H}`}
  xmlns="http://www.w3.org/2000/svg"
  style="display: block; max-width: 100%; margin: 2rem 0; overflow: visible;"
  role="img"
  aria-label="Head structure comparison: MHA, MQA, and GQA (G=2)"
>
  {columns.map(({ label, sublabel }, colIdx) => {
    const cx = colX[colIdx];
    const qxs = qxArr(cx);
    const kvs = kvCenters[colIdx];

    return (
      <g>
        {/* Column title */}
        <text
          x={cx + COL_W / 2}
          y={PAD_TOP - 10}
          text-anchor="middle"
          font-family="var(--font-sans)"
          font-size="14"
          font-weight="bold"
          fill="var(--text)"
        >{label}</text>

        {/* Connecting lines from each query circle to its KV rect */}
        {qxs.map((qx, i) => (
          <line
            x1={qx}
            y1={Q_Y + CIRCLE_R}
            x2={kvTargetX(colIdx, i)}
            y2={KV_Y}
            stroke="var(--border)"
            stroke-width="1"
          />
        ))}

        {/* Query head circles */}
        {qxs.map((qx) => (
          <circle
            cx={qx}
            cy={Q_Y}
            r={CIRCLE_R}
            fill="var(--accent)"
          />
        ))}

        {/* K/V rectangles */}
        {kvs.map((kvcx) => (
          <rect
            x={kvcx - KV_W / 2}
            y={KV_Y}
            width={KV_W}
            height={KV_H}
            fill="var(--bg-subtle)"
            stroke="var(--text-muted)"
            stroke-width="1"
            rx="2"
          />
        ))}

        {/* Sublabel */}
        <text
          x={cx + COL_W / 2}
          y={SUBLABEL_Y}
          text-anchor="middle"
          font-family="var(--font-sans)"
          font-size="12"
          fill="var(--text-muted)"
        >{sublabel}</text>
      </g>
    );
  })}
</svg>
