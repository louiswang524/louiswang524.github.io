---
const W = 560, H = 150;
// Bar dimensions
const BAR_X = 20, BAR_Y = 55, BAR_H = 32;
const BAR_TOTAL_W = W - 40; // 520

// Proportions: reconstruction=5%, prior=3%, denoising=92%
const RECON_W  = Math.round(BAR_TOTAL_W * 0.05);  // 26
const PRIOR_W  = Math.round(BAR_TOTAL_W * 0.03);  // 16
const DENOISE_W = BAR_TOTAL_W - RECON_W - PRIOR_W; // 478

const RECON_X  = BAR_X;
const PRIOR_X  = RECON_X + RECON_W;
const DENOISE_X = PRIOR_X + PRIOR_W;
---

<svg
  width="100%"
  viewBox={`0 0 ${W} ${H}`}
  xmlns="http://www.w3.org/2000/svg"
  style="display:block; max-width:100%; margin:2rem 0; overflow:visible;"
  role="img"
  aria-label="ELBO decomposition showing reconstruction, prior matching, and denoising matching terms"
>
  <title>ELBO decomposition: denoising matching term dominates; reconstruction and prior matching are small</title>

  {/* ── Title ── */}
  <text x={W / 2} y={18} text-anchor="middle" font-family="var(--font-sans)" font-size="12" font-weight="600" fill="var(--text)">ELBO = reconstruction + prior matching + denoising matching</text>

  {/* ── Reconstruction segment ── */}
  <rect x={RECON_X} y={BAR_Y} width={RECON_W} height={BAR_H} rx="3"
    fill="var(--accent)" fill-opacity="0.4" stroke="var(--accent)" stroke-width="1.5" />

  {/* ── Prior matching segment ── */}
  <rect x={PRIOR_X} y={BAR_Y} width={PRIOR_W} height={BAR_H} rx="0"
    fill="var(--border)" fill-opacity="0.6" stroke="var(--border)" stroke-width="1" />

  {/* ── Denoising matching segment ── */}
  <rect x={DENOISE_X} y={BAR_Y} width={DENOISE_W} height={BAR_H} rx="3"
    fill="var(--accent)" fill-opacity="0.85" stroke="var(--accent)" stroke-width="1.5" />
  <text x={DENOISE_X + DENOISE_W / 2} y={BAR_Y + BAR_H / 2 + 5} text-anchor="middle"
    font-family="var(--font-sans)" font-size="12" font-weight="600" fill="white">
    Denoising matching — dominant signal
  </text>

  {/* ── Labels above ── */}
  {/* Reconstruction label */}
  <line x1={RECON_X + RECON_W / 2} y1={BAR_Y - 2} x2={RECON_X + RECON_W / 2} y2={BAR_Y - 14} stroke="var(--accent)" stroke-width="1" />
  <text x={RECON_X + RECON_W / 2} y={BAR_Y - 16} text-anchor="middle" font-family="var(--font-sans)" font-size="10" fill="var(--accent)">Reconstruction</text>

  {/* Prior matching label */}
  <line x1={PRIOR_X + PRIOR_W / 2} y1={BAR_Y - 2} x2={PRIOR_X + PRIOR_W / 2 - 20} y2={BAR_Y - 14} stroke="var(--text-muted)" stroke-width="1" />
  <text x={PRIOR_X + PRIOR_W / 2 - 22} y={BAR_Y - 16} text-anchor="middle" font-family="var(--font-sans)" font-size="10" fill="var(--text-muted)">Prior ≈ 0</text>

  {/* ── Annotation below ── */}
  <line x1={DENOISE_X + 10} y1={BAR_Y + BAR_H + 2} x2={DENOISE_X + DENOISE_W - 10} y2={BAR_Y + BAR_H + 2} stroke="var(--accent)" stroke-width="1" stroke-opacity="0.5" />
  <text x={DENOISE_X + DENOISE_W / 2} y={BAR_Y + BAR_H + 16} text-anchor="middle"
    font-family="var(--font-sans)" font-size="11" fill="var(--text-muted)">
    Sum over t = 2…T → simplifies to 𝓛_simple
  </text>
</svg>
