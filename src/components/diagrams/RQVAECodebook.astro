---
// ── Layout constants ──
const W = 580, H = 325;
const BOX_W = 175, BOX_H = 34;
const LP_X = 20;
const LP_CX = LP_X + BOX_W / 2; // center x of left-panel boxes = 107.5

// Y positions (top of each box in left panel)
const EMB_Y = 20;
const VQ1_Y = 80;
const VQ2_Y = 146;
const VQ3_Y = 212;
const CODE_Y = 268;

// Token boxes (right of each VQ box)
const TOK_X = LP_X + BOX_W + 18; // = 213
const TOK_W = 42, TOK_H = 28;
const tokOffsetY = (BOX_H - TOK_H) / 2; // = 3

// Residual label midpoints
const RES1_Y = (VQ1_Y + BOX_H + VQ2_Y) / 2;
const RES2_Y = (VQ2_Y + BOX_H + VQ3_Y) / 2;

// Right panel: prefix sharing
const RP_X = 310;
const RP_TITLE_Y = 30;
const RP_ROW1_Y = 65;
const RP_ROW2_Y = 125;
const T2W = 46, T2H = 34, T2GAP = 8;
const RP_LABEL_X = RP_X + 4;
const RP_T0 = RP_X + 58;           // C1 box x
const RP_T1 = RP_T0 + T2W + T2GAP; // C2 box x
const RP_T2 = RP_T1 + T2W + T2GAP; // C3 box x
const RP_CONTENT_CX = RP_T0 + (3 * T2W + 2 * T2GAP) / 2;
---

<svg
  width="100%"
  viewBox={`0 0 ${W} ${H}`}
  xmlns="http://www.w3.org/2000/svg"
  style="display:block; max-width:100%; margin:2rem 0; overflow:visible;"
  role="img"
  aria-label="RQ-VAE codebook: hierarchical item tokenization with prefix sharing"
>
  <title>RQ-VAE codebook: hierarchical item tokenization with prefix sharing</title>
  <defs>
    <marker id="rq-arr" markerWidth="6" markerHeight="6" refX="5" refY="3" orient="auto">
      <path d="M0,0 L6,3 L0,6 Z" fill="var(--text-muted)" />
    </marker>
  </defs>

  {/* ── LEFT PANEL: quantization pipeline ── */}

  {/* Item Embedding */}
  <rect x={LP_X} y={EMB_Y} width={BOX_W} height={BOX_H} rx="4"
    fill="var(--bg-subtle)" stroke="var(--border)" stroke-width="1.5" />
  <text x={LP_CX} y={EMB_Y + BOX_H / 2 + 5} text-anchor="middle"
    font-family="var(--font-sans)" font-size="13" fill="var(--text)">Item Embedding</text>

  {/* Arrow: EMB → VQ1 */}
  <line x1={LP_CX} y1={EMB_Y + BOX_H + 4} x2={LP_CX} y2={VQ1_Y - 4}
    stroke="var(--text-muted)" stroke-width="1.5" marker-end="url(#rq-arr)" />

  {/* VQ Round 1 */}
  <rect x={LP_X} y={VQ1_Y} width={BOX_W} height={BOX_H} rx="4"
    fill="var(--bg)" stroke="var(--accent)" stroke-width="1.5" />
  <text x={LP_CX} y={VQ1_Y + BOX_H / 2 + 5} text-anchor="middle"
    font-family="var(--font-sans)" font-size="13" fill="var(--text)">VQ Round 1</text>
  <line x1={LP_X + BOX_W + 4} y1={VQ1_Y + BOX_H / 2}
        x2={TOK_X - 4}         y2={VQ1_Y + BOX_H / 2}
    stroke="var(--text-muted)" stroke-width="1.5" marker-end="url(#rq-arr)" />
  <rect x={TOK_X} y={VQ1_Y + tokOffsetY} width={TOK_W} height={TOK_H} rx="3"
    fill="var(--accent)" fill-opacity="0.2" stroke="var(--accent)" stroke-width="1.5" />
  <text x={TOK_X + TOK_W / 2} y={VQ1_Y + BOX_H / 2 + 5} text-anchor="middle"
    font-family="var(--font-sans)" font-size="12" font-weight="600" fill="var(--accent)">C₁</text>

  {/* Arrow + residual label: VQ1 → VQ2 */}
  <line x1={LP_CX} y1={VQ1_Y + BOX_H + 4} x2={LP_CX} y2={VQ2_Y - 4}
    stroke="var(--text-muted)" stroke-width="1.5" marker-end="url(#rq-arr)" />
  <text x={LP_CX + 8} y={RES1_Y + 4}
    font-family="var(--font-sans)" font-size="11" fill="var(--text-muted)">residual ε₁</text>

  {/* VQ Round 2 */}
  <rect x={LP_X} y={VQ2_Y} width={BOX_W} height={BOX_H} rx="4"
    fill="var(--bg)" stroke="var(--accent)" stroke-width="1.5" />
  <text x={LP_CX} y={VQ2_Y + BOX_H / 2 + 5} text-anchor="middle"
    font-family="var(--font-sans)" font-size="13" fill="var(--text)">VQ Round 2</text>
  <line x1={LP_X + BOX_W + 4} y1={VQ2_Y + BOX_H / 2}
        x2={TOK_X - 4}         y2={VQ2_Y + BOX_H / 2}
    stroke="var(--text-muted)" stroke-width="1.5" marker-end="url(#rq-arr)" />
  <rect x={TOK_X} y={VQ2_Y + tokOffsetY} width={TOK_W} height={TOK_H} rx="3"
    fill="var(--accent)" fill-opacity="0.2" stroke="var(--accent)" stroke-width="1.5" />
  <text x={TOK_X + TOK_W / 2} y={VQ2_Y + BOX_H / 2 + 5} text-anchor="middle"
    font-family="var(--font-sans)" font-size="12" font-weight="600" fill="var(--accent)">C₂</text>

  {/* Arrow + residual label: VQ2 → VQ3 */}
  <line x1={LP_CX} y1={VQ2_Y + BOX_H + 4} x2={LP_CX} y2={VQ3_Y - 4}
    stroke="var(--text-muted)" stroke-width="1.5" marker-end="url(#rq-arr)" />
  <text x={LP_CX + 8} y={RES2_Y + 4}
    font-family="var(--font-sans)" font-size="11" fill="var(--text-muted)">residual ε₂</text>

  {/* VQ Round 3 */}
  <rect x={LP_X} y={VQ3_Y} width={BOX_W} height={BOX_H} rx="4"
    fill="var(--bg)" stroke="var(--accent)" stroke-width="1.5" />
  <text x={LP_CX} y={VQ3_Y + BOX_H / 2 + 5} text-anchor="middle"
    font-family="var(--font-sans)" font-size="13" fill="var(--text)">VQ Round 3</text>
  <line x1={LP_X + BOX_W + 4} y1={VQ3_Y + BOX_H / 2}
        x2={TOK_X - 4}         y2={VQ3_Y + BOX_H / 2}
    stroke="var(--text-muted)" stroke-width="1.5" marker-end="url(#rq-arr)" />
  <rect x={TOK_X} y={VQ3_Y + tokOffsetY} width={TOK_W} height={TOK_H} rx="3"
    fill="var(--accent)" fill-opacity="0.2" stroke="var(--accent)" stroke-width="1.5" />
  <text x={TOK_X + TOK_W / 2} y={VQ3_Y + BOX_H / 2 + 5} text-anchor="middle"
    font-family="var(--font-sans)" font-size="12" font-weight="600" fill="var(--accent)">C₃</text>

  {/* Arrow: VQ3 → Code */}
  <line x1={LP_CX} y1={VQ3_Y + BOX_H + 4} x2={LP_CX} y2={CODE_Y - 4}
    stroke="var(--text-muted)" stroke-width="1.5" marker-end="url(#rq-arr)" />

  {/* Item Code box */}
  <rect x={LP_X} y={CODE_Y} width={BOX_W} height={BOX_H} rx="4"
    fill="var(--bg-subtle)" stroke="var(--border)" stroke-width="1.5" />
  <text x={LP_CX} y={CODE_Y + BOX_H / 2 + 5} text-anchor="middle"
    font-family="var(--font-sans)" font-size="13" fill="var(--text)">[ C₁ · C₂ · C₃ ]</text>

  {/* Left panel caption */}
  <text x={LP_CX} y={H - 6} text-anchor="middle"
    font-family="var(--font-sans)" font-size="11" fill="var(--text-muted)">Quantization pipeline</text>

  {/* ── Divider ── */}
  <line x1={RP_X - 14} y1={16} x2={RP_X - 14} y2={H - 16}
    stroke="var(--border)" stroke-width="1" stroke-dasharray="4 3" />

  {/* ── RIGHT PANEL: prefix sharing ── */}

  <text x={RP_CONTENT_CX} y={RP_TITLE_Y} text-anchor="middle"
    font-family="var(--font-sans)" font-size="13" font-weight="600" fill="var(--text)">
    Similar items share prefix
  </text>

  {/* Row labels */}
  <text x={RP_LABEL_X} y={RP_ROW1_Y + T2H / 2 + 5} text-anchor="start"
    font-family="var(--font-sans)" font-size="12" fill="var(--text-muted)">Item A</text>
  <text x={RP_LABEL_X} y={RP_ROW2_Y + T2H / 2 + 5} text-anchor="start"
    font-family="var(--font-sans)" font-size="12" fill="var(--text-muted)">Item B</text>

  {/* Shared tokens C1 and C2 — both rows */}
  {[RP_ROW1_Y, RP_ROW2_Y].map((rowY) => (
    <>
      <rect x={RP_T0} y={rowY} width={T2W} height={T2H} rx="3"
        fill="var(--accent)" fill-opacity="0.2" stroke="var(--accent)" stroke-width="1.5" />
      <text x={RP_T0 + T2W / 2} y={rowY + T2H / 2 + 5} text-anchor="middle"
        font-family="var(--font-sans)" font-size="12" font-weight="600" fill="var(--accent)">C₁</text>
      <rect x={RP_T1} y={rowY} width={T2W} height={T2H} rx="3"
        fill="var(--accent)" fill-opacity="0.2" stroke="var(--accent)" stroke-width="1.5" />
      <text x={RP_T1 + T2W / 2} y={rowY + T2H / 2 + 5} text-anchor="middle"
        font-family="var(--font-sans)" font-size="12" font-weight="600" fill="var(--accent)">C₂</text>
    </>
  ))}

  {/* Different C3 tokens */}
  <rect x={RP_T2} y={RP_ROW1_Y} width={T2W} height={T2H} rx="3"
    fill="var(--bg-subtle)" stroke="var(--border)" stroke-width="1.5" />
  <text x={RP_T2 + T2W / 2} y={RP_ROW1_Y + T2H / 2 + 5} text-anchor="middle"
    font-family="var(--font-sans)" font-size="12" fill="var(--text-muted)">C₃ₐ</text>
  <rect x={RP_T2} y={RP_ROW2_Y} width={T2W} height={T2H} rx="3"
    fill="var(--bg-subtle)" stroke="var(--border)" stroke-width="1.5" />
  <text x={RP_T2 + T2W / 2} y={RP_ROW2_Y + T2H / 2 + 5} text-anchor="middle"
    font-family="var(--font-sans)" font-size="12" fill="var(--text-muted)">C₃ᵦ</text>

  {/* Annotation: shared bracket under C1+C2 */}
  {/* shared bracket ticks */}
  <line x1={RP_T0} y1={RP_ROW2_Y + T2H + 4} x2={RP_T0} y2={RP_ROW2_Y + T2H + 12}
    stroke="var(--accent)" stroke-width="1.5" />
  <line x1={RP_T1 + T2W} y1={RP_ROW2_Y + T2H + 4} x2={RP_T1 + T2W} y2={RP_ROW2_Y + T2H + 12}
    stroke="var(--accent)" stroke-width="1.5" />
  <line x1={RP_T0} y1={RP_ROW2_Y + T2H + 8}
        x2={RP_T1 + T2W} y2={RP_ROW2_Y + T2H + 8}
    stroke="var(--accent)" stroke-width="1.5" />
  <text x={(RP_T0 + RP_T1 + T2W) / 2} y={RP_ROW2_Y + T2H + 22} text-anchor="middle"
    font-family="var(--font-sans)" font-size="11" fill="var(--accent)">shared</text>

  {/* Annotation: differ bracket under C3 */}
  {/* differ bracket ticks */}
  <line x1={RP_T2} y1={RP_ROW2_Y + T2H + 4} x2={RP_T2} y2={RP_ROW2_Y + T2H + 12}
    stroke="var(--text-muted)" stroke-width="1.5" />
  <line x1={RP_T2 + T2W} y1={RP_ROW2_Y + T2H + 4} x2={RP_T2 + T2W} y2={RP_ROW2_Y + T2H + 12}
    stroke="var(--text-muted)" stroke-width="1.5" />
  <line x1={RP_T2} y1={RP_ROW2_Y + T2H + 8}
        x2={RP_T2 + T2W} y2={RP_ROW2_Y + T2H + 8}
    stroke="var(--text-muted)" stroke-width="1.5" />
  <text x={RP_T2 + T2W / 2} y={RP_ROW2_Y + T2H + 22} text-anchor="middle"
    font-family="var(--font-sans)" font-size="11" fill="var(--text-muted)">differ</text>

  {/* Right panel caption */}
  <text x={RP_CONTENT_CX} y={H - 6} text-anchor="middle"
    font-family="var(--font-sans)" font-size="11" fill="var(--text-muted)">Semantic similarity via shared prefix</text>
</svg>
