---
const W = 520, H = 240;
const TOKENS = ["The", "cat", "sat", "on", "the", "mat"];
const N = TOKENS.length;
const TW = 52, TH = 26, TGAP = 6;
const ROW_W = N * TW + (N - 1) * TGAP; // 342
const ROW_X = (W - ROW_W) / 2; // 89

// Timestep rows
const STEPS = ["t = 0", "t = 1", "t = 2", "t = 3", "t = T"];
const ROW_Y = [20, 60, 100, 140, 180];

// Which tokens are masked at each step (true = masked)
const MASKED: boolean[][] = [
  [false, false, false, false, false, false],
  [false, true,  false, false, false, false],
  [false, true,  true,  false, true,  false],
  [true,  true,  true,  false, true,  true ],
  [true,  true,  true,  true,  true,  true ],
];
---

<svg
  width="100%"
  viewBox={`0 0 ${W} ${H}`}
  xmlns="http://www.w3.org/2000/svg"
  style="display:block; max-width:100%; margin:2rem 0; overflow:visible;"
  role="img"
  aria-label="Masked diffusion forward process: tokens are progressively replaced by MASK tokens"
>
  <title>Masked diffusion forward process: at each step, tokens are independently replaced by MASK with probability βₜ</title>

  {/* ── Arrow on right: "Forward process" ── */}
  <defs>
    <marker id="mfp-arr" markerWidth="7" markerHeight="7" refX="6" refY="3.5" orient="auto">
      <path d="M0,0 L7,3.5 L0,7 Z" fill="var(--text-muted)" />
    </marker>
  </defs>
  <line x1={W - 18} y1={ROW_Y[0] + TH / 2} x2={W - 18} y2={ROW_Y[4] + TH / 2}
    stroke="var(--text-muted)" stroke-width="1.5" marker-end="url(#mfp-arr)" />
  <text x={W - 8} y={(ROW_Y[0] + ROW_Y[4]) / 2 + TH / 2} text-anchor="middle"
    font-family="var(--font-sans)" font-size="10" fill="var(--text-muted)"
    transform={`rotate(90, ${W - 8}, ${(ROW_Y[0] + ROW_Y[4]) / 2 + TH / 2})`}>
    Forward process (corruption) →
  </text>

  {/* ── Rows ── */}
  {STEPS.map((label, step) => (
    <>
      {/* Step label */}
      <text x={ROW_X - 8} y={ROW_Y[step] + TH / 2 + 4} text-anchor="end"
        font-family="var(--font-sans)" font-size="10" fill="var(--text-muted)">{label}</text>

      {/* Token boxes */}
      {TOKENS.map((tok, i) => {
        const masked = MASKED[step][i];
        const x = ROW_X + i * (TW + TGAP);
        return (
          <g>
            <rect x={x} y={ROW_Y[step]} width={TW} height={TH} rx="4"
              fill={masked ? "var(--bg-subtle)" : "var(--accent)"}
              fill-opacity={masked ? "1" : "0.15"}
              stroke={masked ? "var(--border)" : "var(--accent)"}
              stroke-width="1.5"
            />
            <text x={x + TW / 2} y={ROW_Y[step] + TH / 2 + 4} text-anchor="middle"
              font-family="var(--font-sans)" font-size={masked ? "9" : "10"}
              font-weight={masked ? "normal" : "500"}
              fill={masked ? "var(--text-muted)" : "var(--accent)"}>
              {masked ? "[M]" : tok}
            </text>
          </g>
        );
      })}
    </>
  ))}
</svg>
