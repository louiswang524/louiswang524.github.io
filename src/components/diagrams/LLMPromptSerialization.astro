---
const W = 540, H = 290;
const BOX_X = 20;
const PROMPT_W = 500;
const PROMPT_Y = 10;
const PROMPT_H = 185;
const OUT_Y = 240;
const OUT_H = 40;
const PAD = 16;

// Prompt body positions (all derived from PROMPT_Y)
const HIST_HDR_Y   = PROMPT_Y + 26;  // [User History] header baseline
const ITEM1_Y      = PROMPT_Y + 48;  // first history item
const ITEM2_Y      = PROMPT_Y + 68;  // second history item
const ITEM3_Y      = PROMPT_Y + 88;  // third history item
const SEP_Y        = PROMPT_Y + 102; // separator line
const TASK_HDR_Y   = PROMPT_Y + 122; // [Task] header baseline
const TASK_TXT_Y   = PROMPT_Y + 142; // task instruction text
const CURSOR_Y     = PROMPT_Y + 152; // cursor rect top
const CURSOR_TXT_Y = PROMPT_Y + 166; // [GENERATE →] text baseline
---

<svg
  width="100%"
  viewBox={`0 0 ${W} ${H}`}
  xmlns="http://www.w3.org/2000/svg"
  style="display:block; max-width:100%; margin:2rem 0; overflow:visible;"
  role="img"
  aria-label="LLM prompt serialization: user history formatted as a text prompt for recommendation"
>
  <title>LLM prompt serialization: user history formatted as a text prompt for recommendation</title>
  <defs>
    <marker id="llm-arr" markerWidth="6" markerHeight="6" refX="5" refY="3" orient="auto">
      <path d="M0,0 L6,3 L0,6 Z" fill="var(--text-muted)" />
    </marker>
  </defs>

  {/* Prompt box */}
  <rect x={BOX_X} y={PROMPT_Y} width={PROMPT_W} height={PROMPT_H} rx="6"
    fill="var(--bg-subtle)" stroke="var(--border)" stroke-width="1.5" />

  {/* [User History] header */}
  <text x={BOX_X + PAD} y={HIST_HDR_Y}
    font-family="var(--font-mono)" font-size="11" fill="var(--text-muted)">[User History]</text>

  {/* History items */}
  <text x={BOX_X + PAD + 14} y={ITEM1_Y}
    font-family="var(--font-sans)" font-size="12" fill="var(--text)">
    "Introduction to Python"  ·  watched 3 days ago
  </text>
  <text x={BOX_X + PAD + 14} y={ITEM2_Y}
    font-family="var(--font-sans)" font-size="12" fill="var(--text)">
    "ML Crash Course"  ·  watched 2 days ago
  </text>
  <text x={BOX_X + PAD + 14} y={ITEM3_Y}
    font-family="var(--font-sans)" font-size="12" fill="var(--text)">
    "Deep Learning with PyTorch"  ·  watched 1 day ago
  </text>

  {/* Separator line */}
  <line x1={BOX_X + PAD} y1={SEP_Y}
        x2={BOX_X + PROMPT_W - PAD} y2={SEP_Y}
    stroke="var(--border)" stroke-width="1" />

  {/* [Task] header */}
  <text x={BOX_X + PAD} y={TASK_HDR_Y}
    font-family="var(--font-mono)" font-size="11" fill="var(--text-muted)">[Task]</text>
  <text x={BOX_X + PAD + 14} y={TASK_TXT_Y}
    font-family="var(--font-sans)" font-size="12" fill="var(--text)">
    Recommend the next item this user will watch:
  </text>

  {/* Blinking cursor token */}
  <rect x={BOX_X + PAD + 14} y={CURSOR_Y} width={10} height={20} rx="2"
    fill="var(--accent)" fill-opacity="0.5" />
  <text x={BOX_X + PAD + 30} y={CURSOR_TXT_Y}
    font-family="var(--font-mono)" font-size="11" fill="var(--text-muted)">[GENERATE →]</text>

  {/* Arrow from prompt to output */}
  <line x1={BOX_X + PROMPT_W / 2} y1={PROMPT_Y + PROMPT_H + 4}
        x2={BOX_X + PROMPT_W / 2} y2={OUT_Y - 4}
    stroke="var(--text-muted)" stroke-width="1.5" marker-end="url(#llm-arr)" />
  <text x={BOX_X + PROMPT_W / 2 + 8} y={(PROMPT_Y + PROMPT_H + OUT_Y) / 2 + 4}
    text-anchor="start"
    font-family="var(--font-sans)" font-size="11" fill="var(--text-muted)">autoregressive generation</text>

  {/* Output box */}
  <rect x={BOX_X} y={OUT_Y} width={PROMPT_W} height={OUT_H} rx="6"
    fill="var(--bg)" stroke="var(--accent)" stroke-width="1.5" />
  <text x={BOX_X + PROMPT_W / 2} y={OUT_Y + OUT_H / 2 + 5} text-anchor="middle"
    font-family="var(--font-sans)" font-size="13" fill="var(--text)">
    "Neural Networks for Beginners"  (video)
  </text>
</svg>
