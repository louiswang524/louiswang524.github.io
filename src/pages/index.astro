---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import { getCollection } from 'astro:content';
import { readingTime } from '../utils/readingTime';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);
---

<BaseLayout title="Louis Wang">
  <Header slot="header" />
  <main>
    <div class="container">
      <section class="hero">
        <h1>Louis Wang</h1>
        <p>
          ML engineer at <strong>Netflix</strong>, previously at <strong>Snap</strong>. Based in San Francisco.
          I work on recommendation systems and LLM-powered applications — ranging from generative retrieval
          and semantic IDs to agentic AI and vector quantization.
        </p>
        <p style="margin-top: 0.75rem;">
          This blog is where I write about things I find interesting: large-scale RecSys, LLM agents,
          ML infrastructure, and the occasional deep dive into model architecture.
        </p>
      </section>

      <section>
        <h2 class="section-label">Recent posts</h2>
        <ul class="post-list">
          {posts.map(post => (
            <li>
              <p class="post-meta">
                {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                <span class="meta-sep">·</span>
                {readingTime(post.body)}
              </p>
              <h2><a href={`/blog/${post.slug}`}>{post.data.title}</a></h2>
              <p class="post-desc">{post.data.description}</p>
            </li>
          ))}
        </ul>
        {posts.length > 0 && (
          <p style="margin-top: 1.5rem; font-size: 0.9rem;">
            <a href="/blog">All posts →</a>
          </p>
        )}
      </section>
    </div>
  </main>
</BaseLayout>
