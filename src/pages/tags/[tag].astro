---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import { getCollection } from 'astro:content';
import { readingTime } from '../../utils/readingTime';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const tags = [...new Set(posts.flatMap(p => p.data.tags ?? []))];
  return tags.map(tag => ({
    params: { tag },
    props: {
      posts: posts
        .filter(p => p.data.tags?.includes(tag))
        .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
    },
  }));
}

const { tag } = Astro.params;
const { posts } = Astro.props;
---

<BaseLayout title={`#${tag} — Louis Wang`}>
  <Header slot="header" />
  <main>
    <div class="container">
      <h1 class="page-title">
        <a href="/tags" style="font-weight: 400; color: var(--text-muted)">Tags</a>
        <span style="color: var(--text-muted); margin: 0 0.4rem">›</span>
        #{tag}
        <span style="font-size: 1rem; font-weight: 400; color: var(--text-muted); margin-left: 0.5rem">{posts.length} post{posts.length !== 1 ? 's' : ''}</span>
      </h1>
      <ul class="post-list">
        {posts.map(post => (
          <li>
            <p class="post-meta">
              {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              <span class="meta-sep">·</span>
              {readingTime(post.body)}
            </p>
            <h2><a href={`/blog/${post.slug}`}>{post.data.title}</a></h2>
            <p class="post-desc">{post.data.description}</p>
          </li>
        ))}
      </ul>
    </div>
  </main>
</BaseLayout>
